# Copiá este archivo como .env y completá los valores

# MongoDB Atlas (gratuito) o local
MONGO_URI=mongodb://localhost:27017/ne3

# Clave de API — generá una larga y random (64+ caracteres)
# El frontend y los otros servicios deben mandarla en el header x-api-key
API_KEY=cambiar-por-una-clave-larga-y-random

# Orígenes permitidos por CORS, separados por coma
ALLOWED_ORIGINS=http://localhost:5173,https://ne3-app.vercel.app

# Puerto del servidor
PORT=3000
